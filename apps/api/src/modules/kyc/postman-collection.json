{
  "info": {
    "name": "Kindlink KYC Testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Mock KYC Session",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const data = pm.response.json();",
              "  pm.environment.set('session_id', data.sessionId);",
              "  const redirectUrl = data.redirectUrl;",
              "  const externalRef = redirectUrl.split('/').pop();",
              "  pm.environment.set('external_ref', externalRef);",
              "  console.log('Session ID:', data.sessionId);",
              "  console.log('External Ref:', externalRef);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"provider\": \"mock\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/kyc/sessions",
          "host": ["{{base_url}}"],
          "path": ["kyc", "sessions"]
        }
      },
      "response": []
    },
    {
      "name": "2. Get Latest KYC Status",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/kyc/sessions/latest",
          "host": ["{{base_url}}"],
          "path": ["kyc", "sessions", "latest"]
        }
      },
      "response": []
    },
    {
      "name": "3. Mock Webhook - Approve KYC",
      "event": [
        {
          "listen": "pre-request",
          "script": {
            "exec": [
              "// Validate external_ref is set",
              "const externalRef = pm.environment.get('external_ref');",
              "if (!externalRef) {",
              "  console.error('ERROR: external_ref not set!');",
              "  console.log('Run request #1 first to get external_ref');",
              "  pm.execution.skipRequest(true);",
              "} else {",
              "  console.log('Using external_ref:', externalRef);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"externalRef\": \"{{external_ref}}\",\n  \"decision\": \"APPROVED\",\n  \"fullName\": \"John Doe\",\n  \"dob\": \"1990-01-01\",\n  \"reason\": null\n}"
        },
        "url": {
          "raw": "{{base_url}}/kyc/webhook/mock",
          "host": ["{{base_url}}"],
          "path": ["kyc", "webhook", "mock"]
        }
      },
      "response": []
    },
    {
      "name": "4. Verify Status Updated to APPROVED",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/kyc/sessions/latest",
          "host": ["{{base_url}}"],
          "path": ["kyc", "sessions", "latest"]
        }
      },
      "response": []
    },
    {
      "name": "5. Mock Webhook - Reject KYC",
      "event": [
        {
          "listen": "pre-request",
          "script": {
            "exec": [
              "// This test will fail if you haven't run #1 first",
              "const externalRef = pm.environment.get('external_ref');",
              "if (!externalRef) {",
              "  console.error('ERROR: Set external_ref first by running request #1');",
              "  pm.execution.skipRequest(true);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"externalRef\": \"{{external_ref}}\",\n  \"decision\": \"REJECTED\",\n  \"fullName\": \"Jane Smith\",\n  \"reason\": \"Document expired\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/kyc/webhook/mock",
          "host": ["{{base_url}}"],
          "path": ["kyc", "webhook", "mock"]
        }
      },
      "response": []
    },
    {
      "name": "6. Create Sumsub KYC Session (requires API keys)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"provider\": \"sumsub\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/kyc/sessions",
          "host": ["{{base_url}}"],
          "path": ["kyc", "sessions"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "your_jwt_token_here",
      "type": "string"
    },
    {
      "key": "session_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "external_ref",
      "value": "",
      "type": "string"
    }
  ]
}
