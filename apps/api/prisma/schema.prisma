generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  tokens                RefreshToken[]
  createdCampaigns      Campaign[] @relation("CampaignCreator")
  reviewedCampaigns     Campaign[] @relation("CampaignReviewer")
  favorites             Favorite[]
  viewHistories         CampaignViewHistory[]

  tokens            RefreshToken[]
  createdCampaigns  Campaign[]            @relation("CampaignCreator")
  reviewedCampaigns Campaign[]            @relation("CampaignReviewer")
  favorites         Favorite[]
  participations    CampaignParticipant[]

  @@map("users")
}

model RefreshToken {
  id        String @id @default(uuid())
  tokenHash String
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
  @@map("refresh_tokens")
}

enum Role {
  USER
  ADMIN
}

enum CampaignStatus {
  DRAFT
  PENDING
  ACTIVE
  REJECTED
  PAUSED
  COMPLETED
}

model Campaign {
  id            String @id @default(uuid())
  creatorUserId String @map("creator_user_id")

  title       String @db.VarChar(255)
  description String @db.Text

  category      String  @db.VarChar(100)
  locationText  String  @map("location_text") @db.VarChar(255)
  coverImageUrl String? @map("cover_image_url") @db.VarChar(500)

  // numeric
  fundingGoalAmount     Decimal @map("funding_goal_amount") @db.Decimal(18, 2)
  minimumDonationAmount Decimal @map("minimum_donation_amount") @db.Decimal(18, 2)

  startAt                  DateTime @map("start_at")
  endAt                    DateTime @map("end_at")
  autoCloseWhenGoalReached Boolean  @default(true) @map("auto_close_when_goal_reached")

  status CampaignStatus @default(DRAFT)

  reviewNote        String?   @map("review_note") @db.Text
  reviewedByAdminId String?   @map("reviewed_by_admin_id")
  reviewedAt        DateTime? @map("reviewed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // relations
  creatorUser              User            @relation("CampaignCreator", fields: [creatorUserId], references: [id], onDelete: Restrict)
  reviewedByAdmin          User?           @relation("CampaignReviewer", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  favorites                Favorite[]
  viewHistories            CampaignViewHistory[]
  creatorUser     User                  @relation("CampaignCreator", fields: [creatorUserId], references: [id], onDelete: Restrict)
  reviewedByAdmin User?                 @relation("CampaignReviewer", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  favorites       Favorite[]
  participants    CampaignParticipant[]

  @@index([status])
  @@index([creatorUserId])
  @@index([category])
  @@map("campaigns")
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  campaignId String   @map("campaign_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([userId, createdAt])
  @@index([campaignId])
  @@map("favorites")
}

model CampaignViewHistory {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  campaignId String   @map("campaign_id")
  viewedAt   DateTime @default(now()) @map("viewed_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([userId, viewedAt])
  @@index([campaignId])
  @@map("campaign_view_histories")
enum ParticipationStatus {
  JOINED
  LEFT
}

model CampaignParticipant {
  id         String @id @default(uuid())
  userId     String @map("user_id")
  campaignId String @map("campaign_id")

  status   ParticipationStatus @default(JOINED)
  joinedAt DateTime            @default(now()) @map("joined_at")
  leftAt   DateTime?           @map("left_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([userId])
  @@index([campaignId])
  @@index([userId, status])
  @@index([campaignId, status])
  @@map("campaign_participants")
}
