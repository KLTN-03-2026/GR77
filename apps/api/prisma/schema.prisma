generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                                    String                    @id @default(uuid())
  email                                 String                    @unique
  username                              String
  password                              String
  role                                  Role                      @default(USER)
  createdAt                             DateTime                  @default(now())
  updatedAt                             DateTime                  @updatedAt
  is_verified                           Boolean                   @default(false)
  verification_code                     String?
  verification_expires                  DateTime?
  last_resend_at                        DateTime?
  verification_resend_count             Int                       @default(0)
  is_locked                             Boolean                   @default(false)
  lock_reason                           String?                   @db.VarChar(500)
  locked_at                             DateTime?
  participations                        CampaignParticipant[]
  campaignViewHistories                 CampaignViewHistory[]
  createdCampaigns                      Campaign[]                @relation("CampaignCreator")
  reviewedCampaigns                     Campaign[]                @relation("CampaignReviewer")
  donations                             Donation[]
  favorites                             Favorite[]
  notifications                         Notification[]
  tokens                                RefreshToken[]
  reports_submitter                     Report[]                  @relation("reports_submitter_idTousers")
  reports_target                        Report[]                  @relation("reports_target_user_idTousers")
  userActionLogs                        UserActionLog[]
  balance                               Decimal                   @default(0) @db.Decimal(18, 2)
  walletAddress                        String?                   @unique @map("wallet_address")
  walletTransactions                    WalletTransaction[]

  @@map("users")
}

model WalletTransaction {
  id          String                   @id @default(uuid())
  userId      String                   @map("user_id")
  type        WalletTransactionType
  amount      Decimal                  @db.Decimal(18, 2)
  status      PaymentTransactionStatus @default(PENDING)
  orderId     String?                  @unique @map("order_id")
  description String?
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("wallet_transactions")
}

enum WalletTransactionType {
  TOPUP
  WITHDRAW
  DONATION
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Campaign {
  id                       String                    @id @default(uuid())
  creatorUserId            String                    @map("creator_user_id")
  title                    String                    @db.VarChar(255)
  description              String
  category                 String                    @db.VarChar(100)
  locationText             String                    @map("location_text") @db.VarChar(255)
  coverImageUrl            String?                   @map("cover_image_url") @db.VarChar(500)
  fundingGoalAmount        Decimal                   @map("funding_goal_amount") @db.Decimal(18, 2)
  minimumDonationAmount    Decimal                   @map("minimum_donation_amount") @db.Decimal(18, 2)
  startAt                  DateTime                  @map("start_at")
  endAt                    DateTime                  @map("end_at")
  autoCloseWhenGoalReached Boolean                   @default(true) @map("auto_close_when_goal_reached")
  status                   CampaignStatus            @default(DRAFT)
  reviewNote               String?                   @map("review_note")
  reviewedByAdminId        String?                   @map("reviewed_by_admin_id")
  reviewedAt               DateTime?                 @map("reviewed_at")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  currentRaisedAmount      Decimal                   @default(0) @map("current_raised_amount") @db.Decimal(18, 2)
  donationCount            Int                       @default(0) @map("donation_count")
  fundLedger               CampaignFundLedger[]
  participants             CampaignParticipant[]
  campaignViewHistories    CampaignViewHistory[]
  creatorUser              User                      @relation("CampaignCreator", fields: [creatorUserId], references: [id])
  reviewedByAdmin          User?                     @relation("CampaignReviewer", fields: [reviewedByAdminId], references: [id])
  donations                Donation[]
  favorites                Favorite[]
  reports                  Report[]

  @@index([status])
  @@index([creatorUserId])
  @@index([category])
  @@map("campaigns")
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  campaignId String   @map("campaign_id")
  createdAt  DateTime @default(now()) @map("created_at")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([userId, createdAt])
  @@index([campaignId])
  @@map("favorites")
}

model CampaignParticipant {
  id         String              @id @default(uuid())
  userId     String              @map("user_id")
  campaignId String              @map("campaign_id")
  status     ParticipationStatus @default(JOINED)
  joinedAt   DateTime            @default(now()) @map("joined_at")
  leftAt     DateTime?           @map("left_at")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  campaign   Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([userId])
  @@index([campaignId])
  @@index([userId, status])
  @@index([campaignId, status])
  @@map("campaign_participants")
}

model Donation {
  id                  String               @id @default(uuid())
  userId              String?              @map("user_id")
  campaignId          String               @map("campaign_id")
  amount              Decimal              @db.Decimal(18, 2)
  message             String?              @db.VarChar(500)
  isAnonymous         Boolean              @default(false) @map("is_anonymous")
  status              DonationStatus       @default(PENDING)
  donatedAt           DateTime?            @map("donated_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  paymentMethod       PaymentMethod            @map("payment_method")
  ledgerEntries       CampaignFundLedger[]
  campaign            Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user                User?                @relation(fields: [userId], references: [id])
  paymentTransactions PaymentTransaction[]

  @@index([userId])
  @@index([campaignId])
  @@index([status])
  @@index([campaignId, status])
  @@map("donations")
}

model PaymentTransaction {
  id                String                   @id @default(uuid())
  donationId        String                   @map("donation_id")
  provider          PaymentProvider
  status            PaymentTransactionStatus @default(PENDING)
  orderId           String                   @unique @map("order_id") @db.VarChar(100)
  requestId         String                   @unique @map("request_id") @db.VarChar(100)
  partnerCode       String?                  @map("partner_code") @db.VarChar(100)
  transId           String?                  @map("trans_id") @db.VarChar(100)
  requestType       String?                  @map("request_type") @db.VarChar(50)
  amount            Decimal                  @db.Decimal(18, 2)
  payUrl            String?                  @map("pay_url") @db.VarChar(1000)
  deeplink          String?                  @db.VarChar(1000)
  qrCodeUrl         String?                  @map("qr_code_url") @db.VarChar(1000)
  resultCode        Int?                     @map("result_code")
  responseTime      DateTime?                @map("response_time")
  rawCreateResponse Json?                    @map("raw_create_response")
  rawIpnPayload     Json?                    @map("raw_ipn_payload")
  paidAt            DateTime?                @map("paid_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  donation          Donation                 @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@index([donationId])
  @@index([provider])
  @@index([status])
  @@index([orderId])
  @@map("payment_transactions")
}

model CampaignFundLedger {
  id         String          @id @default(uuid())
  campaignId String          @map("campaign_id")
  donationId String?         @map("donation_id")
  type       LedgerEntryType
  amount     Decimal         @db.Decimal(18, 2)
  note       String?         @db.VarChar(500)
  createdAt  DateTime        @default(now()) @map("created_at")
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donation   Donation?       @relation(fields: [donationId], references: [id])

  @@index([campaignId])
  @@index([donationId])
  @@index([campaignId, type])
  @@map("campaign_fund_ledger")
}

model CampaignViewHistory {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  campaignId  String   @map("campaign_id")
  viewedAt    DateTime @default(now()) @map("viewed_at")
  campaigns   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  users       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([campaignId])
  @@index([userId, viewedAt])
  @@map("campaign_view_histories")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  title      String   @db.VarChar(255)
  message    String
  type       String   @db.VarChar(50)
  link       String?  @db.VarChar(500)
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")
  users      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isRead])
  @@index([userId])
  @@map("notifications")
}

model Report {
  id                                  String       @id @default(uuid())
  submitterId                         String       @map("submitter_id")
  targetUserId                        String?      @map("target_user_id")
  targetCampaignId                    String?      @map("target_campaign_id")
  reason                              String       @db.VarChar(500)
  details                             String?
  status                              ReportStatus @default(PENDING)
  createdAt                           DateTime     @default(now()) @map("created_at")
  resolvedAt                          DateTime?    @map("resolved_at")
  resolvedById                        String?      @map("resolved_by_id")
  users_reports_submitter_idTousers   User         @relation("reports_submitter_idTousers", fields: [submitterId], references: [id])
  campaigns                           Campaign?    @relation(fields: [targetCampaignId], references: [id])
  users_reports_target_user_idTousers User?        @relation("reports_target_user_idTousers", fields: [targetUserId], references: [id])

  @@map("reports")
}

model UserActionLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String   @db.VarChar(100)
  details    String?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")
  users      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([userId])
  @@map("user_action_logs")
}

enum Role {
  USER
  ADMIN
  ORGANIZER
}

enum CampaignStatus {
  DRAFT
  PENDING
  ACTIVE
  REJECTED
  PAUSED
  COMPLETED
}

enum ParticipationStatus {
  JOINED
  LEFT
}

enum PaymentMethod {
  MOMO
  VNPAY
  BANK_TRANSFER
  WALLET
  CRYPTO
  PAYOS
}

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum PaymentProvider {
  MOMO
  VNPAY
  INTERNAL
  BLOCKCHAIN
  PAYOS
}

enum PaymentTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  EXPIRED
}

enum LedgerEntryType {
  DONATION_IN
  REFUND_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}
